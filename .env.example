# =============================================================================
# UGC26 — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
#
#   cp .env.example .env.local
#
# DO NOT commit .env.local — it contains secrets.
# =============================================================================

# ─── Node ────────────────────────────────────────────────────────────────────
# Set automatically by Next.js; override only if you need explicit control.
NODE_ENV="development"

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (REQUIRED)
# Free managed Postgres options:
#   https://neon.tech        — serverless, generous free tier
#   https://supabase.com     — full Postgres + extras
#   https://railway.app      — simple add-on
DATABASE_URL="postgresql://user:password@localhost:5432/ugc26"

# ─── NextAuth / JWT ──────────────────────────────────────────────────────────
# Secret used to sign JWTs and session tokens (REQUIRED)
# Generate a secure value with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Canonical URL of your app — NextAuth uses this for callback URLs.
# Must match your production domain exactly (no trailing slash).
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Transactional email via Resend (https://resend.com)
# Steps to get started:
#   1. Create a free account at https://resend.com
#   2. Add and verify your sending domain
#   3. Add DNS records: SPF, DKIM, DMARC (shown in the Resend dashboard)
#   4. Create an API key and paste it below
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# The "From" address shown to recipients — must use a verified Resend domain.
EMAIL_FROM="UGC26 <noreply@ugc26.dz>"

# Internal team address that receives contact-form submissions and alerts.
TEAM_EMAIL="contact@ugc26.dz"

# ─── SMTP (alternative / legacy mailer) ──────────────────────────────────────
# Optional SMTP URL used as a fallback transport when RESEND_API_KEY is absent.
# Format: smtp://user:password@host:port  (use smtps:// for TLS)
# Leave blank if you are using Resend exclusively.
SMTP_URL=""

# ─── Redis ───────────────────────────────────────────────────────────────────
# Required for:
#   • Rate limiting
#   • Real-time SSE (pub/sub for conversations & notifications)
#   • Background job queue (BullMQ)
#
# Free managed Redis options:
#   https://upstash.com      — serverless, HTTP-compatible
#   Railway / Render Redis add-on
#
# Leave blank in development to disable these features gracefully.
REDIS_URL="redis://localhost:6379"

# ─── App URL (public) ────────────────────────────────────────────────────────
# Full public URL of the app, including protocol.
# Used in email links, sitemap generation, and Open Graph tags.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── SATIM Payment Gateway (Algeria) ─────────────────────────────────────────
# Algerian online payment gateway — https://satim-dz.com
#
# Leave all SATIM_* values blank in development; the app will use a stub that
# simulates the payment flow without contacting the gateway.
#
# For production credentials, contact SATIM directly or your acquiring bank.
SATIM_TERMINAL_ID=""
SATIM_MERCHANT_ID=""
SATIM_PASSWORD=""
# Base URL for the SATIM REST API (sandbox vs production differ)
SATIM_BASE_URL="https://satim.dz/payment/rest"
